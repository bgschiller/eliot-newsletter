---
import { render, getCollection } from "astro:content";

const pages = await getCollection("pages");
const page = pages.find((p) => p.id === "chalice-lightings");

if (!page) return Astro.redirect("/404");

const { Content } = await render(page);

const title = page.data.title ?? "Chalice Lightings";
const attribution = page.data.attribution;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Eliot Newsletter — {title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <style is:inline>
      /* ============================================
         Chalice Lightings — Single-Column Layout
         8.5×11 print
         ============================================ */

      .chalice-lightings {
        max-width: 38rem;
        margin: 0 auto;
      }

      .chalice-title {
        font-family: var(--font-body);
        font-size: 1.25rem;
        font-weight: bold;
        color: var(--color-accent);
        margin-bottom: 1.25rem;
        text-align: center;
      }

      .chalice-lightings h2 {
        font-size: 1.125rem;
        color: var(--color-accent);
        margin-top: 1.5rem;
        margin-bottom: 0.4rem;
      }

      .chalice-lightings h3 {
        font-size: 1rem;
        font-weight: bold;
        color: var(--color-text);
        margin-top: 1.25rem;
        margin-bottom: 0.3rem;
      }

      .chalice-lightings p {
        margin-bottom: 0.7em;
        line-height: 1.5;
      }

      .chalice-lightings ul,
      .chalice-lightings ol {
        margin-bottom: 0.7em;
        padding-left: 1.5rem;
      }

      .chalice-lightings li {
        margin-bottom: 0.25em;
        line-height: 1.4;
      }

      .chalice-attribution {
        margin-top: 2rem;
        text-align: right;
        font-style: italic;
        color: var(--color-muted);
      }

      /* ============================================
         PRINT — 8.5×11 letter (single column)
         ============================================ */
      @media print {
        @page {
          size: 8.5in 11in;
          margin: 1in;
        }

        body {
          max-width: none;
          padding: 0;
          background: white;
          color: black;
        }
        body::before {
          display: none;
        }

        .back-link {
          display: none;
        }

        .chalice-lightings {
          max-width: none;
        }

        .chalice-title {
          font-size: 16pt;
          font-weight: bold;
          color: black;
          text-align: left;
          margin-bottom: 14pt;
        }

        .chalice-lightings h2 {
          font-size: 14pt;
          font-weight: bold;
          color: black;
          margin-top: 12pt;
          margin-bottom: 4pt;
        }

        .chalice-lightings h3 {
          font-size: 12pt;
          font-weight: bold;
          color: black;
          margin-top: 10pt;
          margin-bottom: 3pt;
        }

        .chalice-lightings p {
          font-size: 11pt;
          margin-bottom: 0;
          orphans: 3;
          widows: 3;
        }

        .chalice-lightings ul,
        .chalice-lightings ol {
          font-size: 11pt;
        }

        .chalice-lightings li {
          font-size: 11pt;
        }

        .chalice-attribution {
          font-size: 10pt;
          font-style: italic;
          color: black;
          margin-top: 18pt;
        }

        a[href]::after {
          content: none !important;
        }
      }
    </style>
  </head>
  <body>
    <nav class="back-link">
      <a href="/">&larr; Back to Newsletter</a>
    </nav>
    <main class="chalice-lightings">
      <h1 class="chalice-title">{title}</h1>
      <Content />
      {attribution && (
        <p class="chalice-attribution">&mdash;{attribution}</p>
      )}
    </main>

  </body>
</html>

---
import { render, getCollection } from "astro:content";
import Schedule from "../components/Schedule.astro";
import Timeslot from "../components/Timeslot.astro";
import AuthorCredit from "../components/AuthorCredit.astro";
import ColumnRow from "../components/ColumnRow.astro";
import Footer from "../components/Footer.astro";
import Article from "../components/Article.astro";

export async function getStaticPaths() {
  const days = await getCollection('days');
  return days
    .filter(d => import.meta.env.DEV || !d.data.draft)
    .map(d => ({
      params: { date: d.data.date.toISOString().split('T')[0] },
    }));
}

const { date } = Astro.params;

const days = await getCollection('days');
const day = days.find(d => {
  const dStr = d.data.date.toISOString().split('T')[0];
  return dStr === date;
});

if (!day) return Astro.redirect('/404');

const { Content } = await render(day);

const dateStr = day.data.date.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const isoDate = day.data.date.toISOString().split('T')[0];

// Print sizes from build-time measurement (pnpm measure)
const { printScheduleSize, printBodySize, printHeadingSize } = day.data;
const printCssVars = printScheduleSize ? `
@media print {
  :root {
    --print-schedule-size: ${printScheduleSize}pt;
    --print-body-size: ${printBodySize}pt;
    --print-heading-size: ${printHeadingSize}pt;
  }
}` : '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Eliot Newsletter — {dateStr}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    {printCssVars && <style is:inline set:html={printCssVars} />}
  </head>
  <body data-date={isoDate} data-draft={String(day.data.draft)} data-dev={String(import.meta.env.DEV)}>
    <header class="page-header">
      <img class="nameplate" src="/the-daily-thread.svg" alt="The Daily Thread" />
      <p class="page-subtitle">{dateStr}</p>
    </header>
    <nav class="back-link">
      <a href="/">&larr; Current Issue</a>
    </nav>
    <main class="page-layout">
      <Content components={{ Schedule, Timeslot, AuthorCredit, ColumnRow, Article }} />
    </main>
    <Footer />
    <script>
			// Grey out events that have already occurred
			(function() {
				const pageDateStr = document.body.dataset.date;
				if (!pageDateStr) return;
				const pageYear = parseInt(pageDateStr.split('-')[0]);

				const monthNames = ['January','February','March','April','May','June',
					'July','August','September','October','November','December'];

				function parseHeadingDate(h2) {
					const text = h2.textContent.trim();
					const match = text.match(/(\w+)\s+(\d{1,2})/);
					if (!match) return null;
					const monthIdx = monthNames.indexOf(match[1]);
					if (monthIdx === -1) return null;
					return { month: monthIdx, day: parseInt(match[2]) };
				}

				function parseTimeToMinutes(timeStr) {
					if (timeStr === 'noon' || timeStr === 'Noon') return 12 * 60;
					const [h, m] = timeStr.split(':').map(Number);
					return h * 60 + (m || 0);
				}

				function greyOutSchedule(scheduleEl) {
					const scheduleType = scheduleEl.dataset.scheduleType || 'late';
					let currentDayDate = null;
					let prevMinutes = null;
					let hasSeenNoon = false;

					const children = scheduleEl.children;
					for (let i = 0; i < children.length; i++) {
						const el = children[i];
						if (el.nodeName === 'H2') {
							currentDayDate = parseHeadingDate(el);
							prevMinutes = null;
							hasSeenNoon = false;
							continue;
						}
						if (!el.classList || !el.classList.contains('timeslot')) continue;
						if (!currentDayDate) continue;
						const timeEl = el.querySelector('.time');
						if (!timeEl) continue;
						const timeMinutes = parseTimeToMinutes(timeEl.textContent.trim());
						let isPM = false, isNextDay = false;
						if (timeMinutes >= 12 * 60 && timeMinutes < 13 * 60) {
							isPM = true; hasSeenNoon = true;
						} else if (timeMinutes >= 1 * 60 && timeMinutes < 6 * 60) {
							isNextDay = prevMinutes !== null && prevMinutes >= 23 * 60;
							if (!isNextDay) isPM = true;
						} else if (timeMinutes >= 6 * 60 && timeMinutes < 12 * 60) {
							// Late schedule: all evening times are PM (never has AM).
							// Early schedule: needs to have passed noon to be PM.
							if (scheduleType === 'late' || hasSeenNoon) isPM = true;
						}
						let hours = Math.floor(timeMinutes / 60);
						if (isPM && hours < 12) hours += 12;
						const eventDate = new Date(pageYear, currentDayDate.month, currentDayDate.day, hours, timeMinutes % 60);
						if (isNextDay) eventDate.setDate(eventDate.getDate() + 1);
						if (eventDate.getTime() < Date.now()) el.classList.add('past');
						prevMinutes = timeMinutes;
					}
				}

				document.querySelectorAll('.schedule--today, .schedule--tomorrow').forEach(greyOutSchedule);
			})();
		</script>

  </body>
</html>
